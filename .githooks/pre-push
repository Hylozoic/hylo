#!/usr/bin/env bash
# Hylo pre-push: if the pushed commits touch apps/backend, run backend tests.
# Push is aborted if tests fail (non-zero exit).
#
# Skip hooks for one push: git push --no-verify  (Git does not run pre-push at all.)
#
# Invoked via apps/web/.husky/pre-push after yarn install (Husky). To use this
# file alone: git config core.hooksPath .githooks
#
# Override default compare branch for new remote branches (merge-base):
#   git config hylo.pre-push-default-branch origin/dev
#
# True enforcement for all pushes needs CI (branch protection + required checks);
# local hooks cannot be forced on every machine without cooperation.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

zero=$(git hash-object --stdin </dev/null | tr '0-9a-f' '0')
default_branch="$(git config --get hylo.pre-push-default-branch || echo origin/dev)"

needs_backend_test=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Deleting a remote branch: skip
  if [[ "$local_sha" == "$zero" ]]; then
    continue
  fi

  # New branch on remote (remote_sha all zeros): compare merge-base..local
  if [[ "$remote_sha" == "$zero" ]]; then
    if base=$(git merge-base "$default_branch" "$local_sha" 2>/dev/null); then
      range="$base..$local_sha"
    else
      # No merge-base (e.g. default branch not fetched): run tests to be safe
      needs_backend_test=1
      continue
    fi
  else
    range="$remote_sha..$local_sha"
  fi

  if git diff --name-only "$range" | grep -q '^apps/backend/'; then
    needs_backend_test=1
  fi
done

if [[ "$needs_backend_test" -eq 1 ]]; then
  echo 'pre-push: apps/backend changed in this push; running apps/backend tests...'
  yarn --cwd apps/backend test
fi
