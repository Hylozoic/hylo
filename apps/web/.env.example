PROXY_HOST=http://hylo-landing.surge.sh
HYLO_COOKIE_NAME=hylo-dev-local
LOCAL_CERT=localhost
HTTPS=false

VITE_API_HOST=http://localhost:3001
VITE_SOCKET_HOST=http://localhost:3001

VITE_FILESTACK_API_KEY=xxx
VITE_MAPBOX_TOKEN=xxx
VITE_MIXPANEL_TOKEN=xxx
VITE_STRIPE_CLIENT_ID=xxx
VITE_INTERCOM_APP_ID=xxx

VITE_FEATURED_GROUP_IDS=1,2
# Isolated Playwright E2E: Postgres Instance based on env var, TCP URL (used by run-isolated-e2e.js for dropdb/createdb + backend)
# E2E_DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:HOST_PORT/hylo_e2e
# E2E_WEB_PORT=3330
# E2E_BACKEND_PORT=3101
# E2E_BACKEND_PORT_RANGE_LO=3101
# E2E_BACKEND_PORT_RANGE_HI=3199
# VITE_DEBUG_CHECK_LOGIN=1
# E2E_FORWARD_BROWSER_LOGS=1

# Optional: set to 1 to run the linter on staged files when committing (pre-commit hook).
# HYLO_LINT_ON_COMMIT=1
